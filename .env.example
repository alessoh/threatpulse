# ── Database ──
# Use your provider's POOLED connection string in production (Neon/Supabase
# pooler). The backend uses NullPool, so every request opens a connection
# through the pooler.
DATABASE_URL=postgresql://threatpulse:threatpulse_dev@localhost:5432/threatpulse

# ── Auth ──
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Anthropic (threat synthesis, advisor, playbooks, digest) ──
ANTHROPIC_API_KEY=
# Optional override; leave empty for the built-in default.
ANTHROPIC_MODEL=

# ── Cron protection (Vercel sends this as a Bearer token to /api/cron/*) ──
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ── Email (Resend) ──
RESEND_API_KEY=
EMAIL_FROM=alerts@yourdomain.com

# ── URLs ──
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Frontend (Vercel frontend project only) ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
