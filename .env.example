# ThreatPulse Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit your .env file to git.

# ── Database ──
# Local Docker default; replace with Supabase / Neon / Railway URL in production.
DATABASE_URL=postgresql://threatpulse:threatpulse_dev@localhost:5432/threatpulse

# ── Authentication ──
# REQUIRED. Generate with: openssl rand -hex 32
# The app refuses to start if this is empty or set to the default.
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Anthropic AI (Claude) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Stripe (payments) ──
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxx

# ── Email (Resend) ──
RESEND_API_KEY=re_your-key-here
EMAIL_FROM=alerts@yourdomain.com

# ── URLs ──
# Used for Stripe redirects and email links. No trailing slash.
FRONTEND_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins for the API.
CORS_ORIGINS=http://localhost:3000

# ── Frontend (read by Next.js at build/runtime) ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_xxxxx
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_xxxxx

# ── Scraping schedule (hours) ──
SCRAPE_CISA_INTERVAL_HOURS=1
SCRAPE_NVD_INTERVAL_HOURS=4
SCRAPE_VENDOR_INTERVAL_HOURS=12
