# ThreatPulse Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/threatpulse

# ── Authentication ──
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Anthropic AI ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxx

# ── Email (Resend) ──
RESEND_API_KEY=re_your-key-here
EMAIL_FROM=alerts@threatpulse.io

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# ── Scraping Schedule ──
SCRAPE_CISA_INTERVAL_HOURS=1
SCRAPE_NVD_INTERVAL_HOURS=4
SCRAPE_VENDOR_INTERVAL_HOURS=12
